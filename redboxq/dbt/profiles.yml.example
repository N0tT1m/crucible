redboxq:
  target: dev
  outputs:
    dev:
      type: clickhouse
      schema: mart
      host: "{{ env_var('CH_HOST', 'localhost') }}"
      port: "{{ env_var('CH_PORT', '9000') | int }}"
      user: "{{ env_var('CH_USER', 'default') }}"
      password: "{{ env_var('CH_PASSWORD', '') }}"
      database: "{{ env_var('CH_DATABASE', 'mart') }}"
      secure: false
      verify: false
      driver: native
      threads: 4
      send_receive_timeout: 300
      cluster_mode: false
