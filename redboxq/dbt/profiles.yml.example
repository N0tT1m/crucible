# dbt-clickhouse profile for redboxq.
#
# Two run modes:
#   * Host-side (host networking): defaults below resolve to
#     localhost:9001, the redboxq ClickHouse host port.
#   * Inside the dbt container (docker compose --profile dbt run):
#     CH_HOST=clickhouse and CH_PORT=9000 are injected by compose.
#
# Override either by exporting CH_HOST / CH_PORT in your shell.

redboxq:
  target: dev
  outputs:
    dev:
      type: clickhouse
      schema: mart
      host: "{{ env_var('CH_HOST', 'localhost') }}"
      port: "{{ env_var('CH_PORT', '9001') | int }}"
      user: "{{ env_var('CH_USER', 'default') }}"
      password: "{{ env_var('CH_PASSWORD', '') }}"
      database: "{{ env_var('CH_DATABASE', 'mart') }}"
      secure: false
      verify: false
      driver: native
      threads: 4
      send_receive_timeout: 300
      cluster_mode: false
