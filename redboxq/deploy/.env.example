# Copy to deploy/.env before `docker compose up`.
#
# Host-published ports (defaults below are non-empire so redboxq can
# coexist with mommy-smoothies-morning-milking + lupes-anal-ytics):
#
#   redboxq dashboard      http://localhost:7000
#   ClickHouse HTTP        http://localhost:8124
#   ClickHouse native      tcp://localhost:9001
#   OTel gRPC              localhost:4327
#   OTel HTTP              localhost:4328

# ---- redboxq (in-network defaults; rarely overridden) ----
REDBOXQ_LISTEN_ADDR=:7000
REDBOXQ_OTLP_ENDPOINT=otel-collector:4317
REDBOXQ_CH_ADDR=clickhouse:9000
REDBOXQ_CH_DATABASE=mart
REDBOXQ_CH_USERNAME=default
REDBOXQ_CH_PASSWORD=

# ---- alerts (all optional) ----
# REDBOXQ_DISCORD_WEBHOOK_URL=
# REDBOXQ_TELEGRAM_BOT_TOKEN=
# REDBOXQ_TELEGRAM_CHAT_ID=
