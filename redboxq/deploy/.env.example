# Copy to deploy/.env before `make up`.

# ---- redboxq ----
REDBOXQ_LISTEN_ADDR=:7000
REDBOXQ_OTLP_ENDPOINT=otel-collector:4317

# ---- ClickHouse ----
REDBOXQ_CH_ADDR=clickhouse:9000
REDBOXQ_CH_DATABASE=mart
REDBOXQ_CH_USERNAME=default
REDBOXQ_CH_PASSWORD=

