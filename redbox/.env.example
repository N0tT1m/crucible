# Default points at the homelab LiteLLM proxy.
REDBOX_BASE_URL=http://localhost:4000/v1
REDBOX_API_KEY=sk-redlab-dev

# Override DB path (default: ./redbox.sqlite)
# REDBOX_DB=/path/to/redbox.sqlite
#
# Or point at the homelab redbox-postgres service (compose: redbox-postgres,
# host port 5444, user/db `redbox`). Replace the password with whatever
# REDBOX_PG_PASSWORD is set to in the homelab .env (default: redbox-dev).
# REDBOX_DB=postgresql://redbox:redbox-dev@192.168.1.78:5444/redbox

# Frontier providers (only needed if pointing redbox directly at them,
# not through LiteLLM).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
