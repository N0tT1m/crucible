# Copy to .env and fill in. .env is gitignored.

# ---- frontier API keys (optional but recommended) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- huggingface token (only needed for gated models like Llama) ----
HF_TOKEN=

# ---- local secrets ----
POSTGRES_PASSWORD=redlab
LITELLM_MASTER_KEY=sk-redlab-dev

# ---- redbox-postgres (dedicated DB for redbox A5 results store, port 5444) ----
REDBOX_PG_PASSWORD=redbox-dev
LANGFUSE_SECRET=change-me-to-a-random-string
LANGFUSE_SALT=change-me-to-a-random-string

# ---- agent default model (must be tool-capable) ----
# Smaller default so first-run is fast. Bump to qwen2.5:32b once pulled.
AGENT_MODEL=qwen2.5:14b
