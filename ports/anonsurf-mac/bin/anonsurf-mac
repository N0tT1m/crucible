#!/usr/bin/env bash
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cmd="${1:-help}"; shift || true
case "$cmd" in
  enable)   exec bash "$HERE/lib/enable.sh"   "$@" ;;
  disable)  exec bash "$HERE/lib/disable.sh"  "$@" ;;
  status)   exec bash "$HERE/lib/status.sh"   "$@" ;;
  changeid) exec bash "$HERE/lib/changeid.sh" "$@" ;;
  help|--help|-h)
    cat <<EOF
anonsurf-mac — force traffic through Tor on macOS.

  enable     Start tor, install pf rules, swap DNS  (sudo)
  disable    Tear down rules, restore DNS, stop tor (sudo)
  status     Show tor process, pf state, current egress IP
  changeid   Randomize MAC + request a new Tor circuit (sudo)

See README.md for the leak caveats.
EOF
    ;;
  *) echo "unknown subcommand: $cmd"; exit 2 ;;
esac
